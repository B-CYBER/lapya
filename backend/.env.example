# Generate secrets with: openssl rand -hex 32
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

DATABASE_URL=sqlite:///./lapya.db

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:5173

# Token lifetime in minutes (7 days for dev)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional: when set, the nutrition chatbot uses real Claude Sonnet 4.6.
# When unset, /api/chat returns a "chat is offline" SSE fallback so the UI still works.


# Email delivery (SMTP).
# Dev: start ./tools/mailpit and use the values below — emails land at http://localhost:8025.
# Prod: swap in real SMTP credentials (Postmark, Resend, SES, your own server).
# If SMTP_HOST is empty the email service prints messages to stdout instead of sending.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Lapya <hello@lapya.test>

# Public-facing app URL used in email links (verification, reset, invite accept).
APP_PUBLIC_URL=http://localhost:5173
